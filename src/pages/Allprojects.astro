---

import MainLayout from "@layouts/MainLayout.astro";
import DemoPopup from "@components/Demo-popup.astro";

const projects = [
    {
        title: "Student Management System",
        desc: "A complete student management system",
        image: "/projects/project-sms.png",
        tech: ["Laravel", "MYSQL","Tailwind CSS"],
        live: "",
        github: "https://github.com/sakthivel171/student_management-system",
        category: "Full Stack",
        status: "Completed",
    },
    {
        title: "Portfolio Website",
        desc: " Personal developer Portfolio built with Astro and Tailwind CSS",
        image: "/projects/portfolio.png",
        tech: ["Astro","Tailwind CSS", "Javascript"],
        live: "",
        github: "https://github.com/sakthivel171/sakthivel-portfolio",
        category: "Frontend",
        status: "Completed",
    },
    {
        title: "CRUD Operation",
        desc: "A complete student management system",
        image: "/projects/crud.png",
        tech: ["PHP","Tailwind CSS", "MYSQL"],
        live: "",
        github: "https://github.com/sakthivel171/CRUD_operation",
        category: "Full Stack",
        status: "Completed",
    },
    {
        title: "Uzhavarbumi website clone",
        desc: "Uzhavarbumi website clone built with Vue.js and Tailwind CSS featuring responsive UI",
        image: "/projects/website.png",
        tech: ["Vue.js", "Javascript", "Tailwind CSS"],
        live: "",
        github: "",
        private: true,
        category: "Frontend",
        status: "Completed",
    },
    {
        title: "Basic Calculator",
        desc: "A clean and responsive calculator application built using HTML, CSS, and JavaScript for performing basic arithmetic operations.",
        image: "/projects/calculator.png",
        tech: ["HTML","CSS", "Javascript"],
        live: "",
        github: "https://github.com/sakthivel171/myproject1",
        category: "Frontend",
        status: "Completed",
    },
    {
        title: "UB Customer App",
        desc: " Customer web app inspired by Uzhavarbumi, developed using Vue.js, JavaScript, and Tailwind CSS with modern UI design and dynamic components.",
        image: "/projects/customer.png",
        tech: ["Vue", "Javascript", "Tailwind CSS"],
        live: "",
        github: "",
        private: true,
        category: "Frontend",
        status: "Completed",
    },
];

const stats = [
    {value: `${projects.length}+`,label: "Projects Built"},
    {value: "3+", label: "Tech Stacks"},
    {value: "1+",label: "Years Building"},
];

const categories = [ "All", ... new Set(projects.map((p) => p.category))];
---
<DemoPopup/>
<MainLayout>
    <section id="allprojects" class="relative min-h-screen overflow-hidden bg-[#050816] text-white px-4 sm:px-6 lg:px-8 pb-24">
        <div class="absolute top-0 left-0 w-96 h-96 bg-indigo-500/10 blur-[160px] rounded-full pointer-events-none"></div>
        <div class="absolute top-1/2 right-0 w-80 h-80 bg-purple-500/10 blur-[140px] rounded-full pointer-events-none"></div>
        <div class="absolute bottom-0 left-1/3 w-72 h-72 bg-indigo-600/10 blur-[120px] rounded-full pointer-events-none"></div>

        <div class="relative max-w-6xl mx-auto">

            <div class="pt-20 pb-14 text-center">
                <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-indigo-500/10 border border-indigo-500/20 text-indigo-400 text-xs font-medium mb-6">
                    <ion-icon name="code-slash-outline"style="font-size:14px;"></ion-icon>
                    What I've Built
                </div>

                <h1 class="text-xl md:text-6xl font-bold leading-tight mb-5">
                    All
                    <span class="bg-gradient-to-r from-indigo-400 to-purple-500 text-transparent bg-clip-text">Projects</span>
                </h1>

                <p class="text-gray-400 text-base max-w-2xl mx-auto leading-relaxed mb-10"> A collection of projects focused on modern UI design, scalable applications and clean development practices.</p>

                <div class="flex flex-wrap justify-center gap-4 mb-8">
                    {stats.map((s) => (
                        <div class="px-6 py-3 bg-white/5 border border-white/10 rounded-2xl text-center min-w-[120px]">
                            <p class="text-2xl font-bold text-indigo-400">{s.value}</p>
                            <p class="text-gray-500 text-xs mt-1">{s.label}</p>
                        </div>
                    ))}
                </div>

                <div class="flex flex-wrap justify-center gap-3 " id="filter-tabs">
                  {categories.map((cat,index) => (
                    <button data-filter={cat} class:list={["filter-btn px-5 py-2 rounded-xl text-sm font-medium transition duration-300",index === 0  ? "bg-gradient-to-r from-indigo-500 to-purple-600 text-white shadow-lg shadow-indigo-500/20"
                : "bg-white/5 border border-white/10 text-gray-400 hover:border-indigo-400/40 hover:text-indigo-300" ]}>{cat}</button>
                  ))}
                </div>
            </div>

            <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3" id="projects-grid">
                {projects.map((project,index) => (
                    <div class="project-card group flex flex-col bg-white/5 border  border-white/10 rounded-2xl overflow-hidden hover:border-indigo-500/40 hover:bg-white/[0.07] transition duration-300" data-category={project.category}>
                        <div class="relative h-52 overflow-hidden bg-[#0f172a] flex items-center justify-center">
                            {project.image ? (
                                <img src={project.image} alt={project.title} class="w-full h-full object-cover group-hover:scale-105 transition duration-500"/>
                            ):(
                                <div class="w-full h-full flex flex-col items-center justify-center bg-gradient-to-br from-[#0f172a] to-[#1e1b4b] gap-3">
                                    <div class="w-16 h-16 rounded-2xl bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center">
                                        <ion-icon name="code-slash-outline"style="font-size:28px; color:#6366f1;"></ion-icon>
                                    </div>
                                    <p class="text-gray-500 text-xs">{project.title}</p>
                                </div>
                            )}

                            {/* <div class:list={["absolute top-3 right-3 flex items-center gap-1.5   px-3 py-1 rounded-full text-[11px] font-medium border",
                                project.status === "Live"? "bg-emerald-500/10 border-emerald-500/20 text-emerald-400"
                                : "bg-indigo-500/10 border-indigo-500/20 text-indigo-300"
                            ]}>
                                <span class:list={["w-1.5 h-1.5 rounded-full", project.status === "Live"? "bg-emerald-400 animate-pulse" : "bg-indigo-400"]}></span>
                                {project.status}
                            </div> */}

                            {/* <div class="absolute top-3 left-3 px-2.5 py-1 rounded-lg bg-black/40 backdrop-blur-sm border border-white/10 text-gray-300 text-[11px] font-medium">{project.category}</div> */}

                        </div>

                        <div class="flex flex-col flex-1 p-5">
                            <h3 class="text-lg font-bold text-white mb-2">{project.title}</h3>
                            <p class="text-gray-400 text-sm leading-relaxed mb-5 flex-1">{project.desc}</p>

                            <div class="flex flex-wrap gap-2 mb-5">
                                {project.tech.map((t) => (
                                    <span class="px-2.5 py-1 rounded-lg bg-indigo-500/10 border border-indigo-500/20 text-indigo-300 text-[11px] font-medium">{t}</span>
                                ))}
                            </div>

                            <div class="flex gap-3">
                                {project.private ? (
                                    <button onclick="alert('This repository is private due to security and business reasons.')"
                                        class="flex-1 flex items-center justify-center gap-2 px-4 py-2 rounded-xl bg-white/5 border border-white/10 text-gray-300 text-sm font-medium hover:border-red-400/40 hover:bg-red-500/10 hover:text-red-300 transition duration-200">
                                        <ion-icon name="lock-closed-outline" style="font-size:16px;"></ion-icon>
                                        Private Repo
                                    </button>
                                    ) : (

                                    <a href={project.github} target="_blank" rel="noopener noreferrer" class="flex-1 flex items-center justify-center gap-2 px-4 py-2 rounded-xl bg-white/5 border border-white/10 text-gray-300 text-sm font-medium hover:border-indigo-400/40 hover:bg-indigo-500/10 hover:text-indigo-300 transition duration-200">
                                        <ion-icon name="logo-github" style="font-size:16px;"></ion-icon>
                                        Github
                                    </a>
                                )}
                               {
                                project.live ? (
                                    <a href={project.live} target="_blank" rel="noopener noreferrer" class="flex-1 flex items-center justify-center gap-2 px-4 py-2 rounded-xl bg-gradient-to-r from-indigo-500 to-purple-600 text-white text-sm font-semibold hover:from-indigo-400 hover:to-purple-500 hover:shadow-lg hover:shadow-indigo-500/20 transition duration-200">
                                        <ion-icon name="open-outline" style="font-size:15px;"></ion-icon>
                                        Live Demo
                                    </a>
                                ) : (
                                    <button  class="demo-btn flex-1 flex items-center justify-center gap-2 px-4 py-2 rounded-xl bg-gradient-to-r from-indigo-500 to-purple-600 text-white text-sm font-semibold hover:from-indigo-400 hover:to-purple-500 hover:shadow-lg hover:shadow-indigo-500/20 transition duration-200">
                                        <ion-icon name="rocket-outline" style="font-size:15px;"></ion-icon>
                                        Live Demo
                                    </button>
                                )
                               }
                            </div>
                        </div>
                    </div>
                ))}
            </div>

            <div id="empty-state" class="hidden text-center py-24">
                <div class="w-16 h-16 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center mx-auto mb-4">
                    <ion-icon name="search-outline" style="font-size:28px; color:#4f46e5;"></ion-icon>
                </div>
                <p class="text-gray-400 text-sm">No projects in this category yet.</p>
            </div>

            <div class="mt-16 bg-gradient-to-r from-indigo-500/10 to-purple-500/10 border border-indigo-500/20 rounded-2xl p-8 text-center">
                <h3 class="text-xl font-bold text-white mb-2">Interested in working together?</h3>
                <p class="text-gray-400 text-sm mb-6 max-w-sm mx-auto">
                    I'm open to freelance projects, Collabrations and full0-time Oppurtinities.
                </p>
                <div class="flex flex-wrap justify-center gap-3">
                    <a href="/#contact" class="flex items-center gap-2 px-6 py-2.5 rounded-xl bg-gradient-to-r from-indigo-500 to-purple-600 text-sm font-semibold hover:from-indigo-400 hover:to-purple-500 hover:scale-105 transition duration-300 shadow-lg shadow-indigo-500/20">
                        <ion-icon name="mail-outline" style="font-size:16px;"></ion-icon>
                        Contact Me
                    </a>
                    <a href="/" class="flex items-center gap-2 px-6 py-2.5 rounded-xl border border-white/10 bg-white/5 text-sm text-gray-300 hover:border-indigo-400/40 hover:bg-indigo-500/10 hover:text-indigo-300 transition duration-200">
                        <ion-icon name="arrow-back-outline" style="font-size:16px;"></ion-icon>
                        Back to Home     
                    </a>
                </div>
            </div>
        </div>
    </section>
</MainLayout>

<script>
    document.addEventListener('DOMContentLoaded',() => {

        const filtersBtns = document.querySelectorAll('.filter-btn');
        const cards = document.querySelectorAll('.project-card');
        const emptyState = document.getElementById('empty-state');

        filtersBtns.forEach((btn) => {
            btn.addEventListener('click', () => {

                const filter = btn.dataset.filter;
    
                filtersBtns.forEach((b) => {
                    b.className = 'filter-btn px-5 py-2 rounded-xl text-sm font-medium transition duration-300 bg-white/5 border border-white/10 text-gray-400 hover:border-indigo-400/40 hover:text-indigo-300'
                });
    
                btn.className =  'filter-btn px-5 py-2 rounded-xl text-sm font-medium transition duration-300 bg-gradient-to-r from-indigo-500 to-purple-600 text-white shadow-lg shadow-indigo-500/20';
    
                let visible = 0;
                cards.forEach((card) => {
                    const match = filter === 'All' || card.dataset.category === filter;
    
                    card.style.display = match ? 'flex' : "none";
    
                    if(match) visible++;
                });

                emptyState ?.classList.toggle('hidden',visible > 0);
            })
        })
    })
</script>