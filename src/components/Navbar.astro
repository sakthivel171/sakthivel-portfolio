---
const navLinks = [
  {name: "Home",href:"#home"},
  {name:"About",href:"#about"},
  {name:"Skills",href:"#skills"},
  {name:"Projects",href:"#projects"},
  {name:"Contact",href:"#contact"},
];

---
<nav class="fixed top-0 left-0 w-full z-50 bg-[#050816]/80 backdrop-blur-lg border-b border-white/10" >
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="h-20 flex items-center justify-between">
      <a href="/" class="flex items-center gap-3">
        <div class="w-11 h-11 rounded-xl bg-gradient-to-r from-indigo-400 to-indigo-600 flex items-center justify-center font-bold text-white text-sm md:text-lg">SK</div>
        <div class="hidden sm:block">
          <h1 class="text-white font-bold text-xl leading-none">SAKTHIVEL</h1>
          <p class="text-gray-400 text-sm">Full Stack Developer</p>
        </div>
      </a>
  
      <div class="hidden md:flex items-center gap-8">
        {navLinks.map((link,index)=> (
          <a href={link.href} class:list={["nav-link relative text-md font-medium transition duration-300 pb-1", index === 0 ? "text-white" : "text-gray-400 hover:text-white"]}>
            {link.name}
            <span class:list={["absolute left-0  -bottom-1 h-[2px] bg-indigo-500 rounded-full transition-all duration-300", index === 0 ? "w-full" : "w-0"]}></span>
          </a>
        ))}
      </div>
  
      <div class="flex items-center gap-3">
        <a href="#" target="_blank" class="hidden sm:flex px-5 py-2 rounded-xl bg-gradient-to-r from-indigo-500 to-purple-600 hover:scale-105 transition-transform duration-300 shadow-lg shadow-indigo-500/30">
          Resume
        </a>
        <button id="menu-btn" class="md:hidden text-white hover:text-indigo-400 transition-all duration-300">
            <ion-icon name="menu-outline" style="font-size:30px;"></ion-icon>
        </button>
      </div>
    </div>
  </div>

  <div id="mobile-menu" class="hidden md:hidden px-6 pb-6">
    <div class="flex flex-col gap-4">
      {navLinks.map((link) => (
        <a href={link.href} class="text-gray-300 hover:text-indigo-400 transition duration-300">
          {link.name}
        </a>
      ))}
      <a href="" target="_blank" class="mt-2 px-5 py-2 rounded-xl bg-gradient-to-r from-indigo-500 to-purple-600 hover:scale-105 transition-transform duration-300 shadow-lg shadow-indigo-500/30 text-center">
        Resume
      </a>
    </div>
  </div>
</nav>

 <script>
  const menuBtn    = document.getElementById("menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");

  menuBtn?.addEventListener("click", () => {
    mobileMenu?.classList.toggle("hidden");
  });

  const mobileLinks = mobileMenu?.querySelectorAll("a");

  mobileLinks?.forEach((link) => {
    link.addEventListener("click", () => {
      mobileMenu?.classList.add("hidden"); // ✅ Fix 1: added ?. here
    });
  });

  
  const DesktopLinks = document.querySelectorAll<HTMLElement>(".nav-link");

  DesktopLinks.forEach((link) => {
    link.addEventListener("click", () => {
      DesktopLinks.forEach((nav) => {
        nav.classList.remove("text-white");
        nav.classList.add("text-gray-400");

        const line = nav.querySelector("span");
        line?.classList.remove("w-full");
        line?.classList.add("w-0");
      });

      // ✅ Fix 3: link is already HTMLElement from the cast above
      link.classList.remove("text-gray-400");
      link.classList.add("text-white");

      const activeLine = link.querySelector("span");
      activeLine?.classList.remove("w-0");
      activeLine?.classList.add("w-full");
    });
  });
</script>