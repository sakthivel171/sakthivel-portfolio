  <div class="absolute top-20 left-10 w-40 h-40 bg-indigo-500/20 blur-[100px] rounded-full"></div>
  <div class="absolute bottom-20 right-10 w-52 h-52 bg-purple-500/20 blur-[120px] rounded-full"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 md:py-16 w-full">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div class="order-2 sm:order-2 md:order-1">
        <p class="text-indigo-400 text-lg tracking-wide mb-2">Hello, I'm</p>
        <h1 class="text-4xl sm:text-5xl lg:text-7xl font-bold leading-tight">Sakthivel N</h1>
        <h2 class="text-2xl md:text-3xl font-semibold bg-gradient-to-r from-indigo-400 to-purple-500 text-transparent bg-clip-text mb-6">Full Stack Web Developer</h2>
        <p class="text-gray-300/80 text-base lg:text-lg leading-relaxed max-w-xl mb-8">I build modern, scalable and high-performance web applications using
          Vue.js, Laravel and Tailwind CSS with clean UI/UX and optimized backend architecture.
        </p>
        

        <div class="flex flex-row gap-4 mt-8 mb-10">
          <a href="/resume/Sakthivel_N_Resume.pdf" target="_blank"class="px-8 py-3 rounded-xl bg-gradient-to-r from-indigo-500 to-purple-600 hover:scale-105 transition-transform duration-300 shadow-lg shadow-indigo-500/30">View Resume</a>
          <a href="#contact" class="px-8 py-3 rounded-xl border border-white/10 bg-white/5 hover:border-indigo-400 hover:bg-indigo-500/10 transition">Contact Me</a>
        </div>

