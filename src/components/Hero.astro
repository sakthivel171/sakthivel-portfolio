<section id="home" class="relative overflow-hidden bg-[#050816] text-white flex items-center pt-14 md:pt-10 lg:pt-20 scroll-mt-15">

  <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_20%,rgba(99,102,241,0.15),transparent_25%)]"></div>
