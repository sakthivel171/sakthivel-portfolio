---
const skills = [
  {
    title: "Frontend Development",
     icon: "color-palette-outline",
    items: [
      {name: "HTML", icon: "/skill/html.png"},
      {name: "Tailwind CSS", icon: "/skill/tailwind.png"},
      {name: "Bootstrap", icon: "/skill/bootstrap.png"},
      {name: "Javascript", icon: "/skill/js.png"},
      {name: "vue.js", icon: "/skill/vue.png"},
    ],
  },
  {
    title: "Backend Development",
    icon: "server-outline",
    items: [
      {name: "PHP", icon: "/skill/php.png"},
      {name: "Laravel", icon: "/skill/laravel.png"},
      {name: "REST APIs", icon: "/skill/api.png"},
      {name: "MYSQL", icon: "/skill/mysql.png"},
      {name: "Livewire",icon: "/skill/livewire.png"}
    ]
  },
  {
    title: "Tools & Cloud",
    icon: "construct-outline",
    items: [
      {name: "Git & Github", icon: "/skill/git.png"},
      {name: "Vs Code", icon: "/skill/vscode.png"},
      {name:"Vercel",icon: "/skill/vercel.png"},
      {name: "AWS", icon: "/skill/aws.png"},
      {name: "Postman", icon: "/skill/postman.png"}
    ],
  },
];

---

<section id="skills" class="relative overflow-hidden py-10 px-4 sm:px-6 lg:px-8 bg-gradient-to-br from-[#020617] via-[#020617] to-[#0f172a] text-white scroll-mt-15">

  <div class="absolute top-0 left-0 w-72 h-72 bg-indigo-500/20 blur-[120px] rounded-full"></div>

  <div class="absolute bottom-0 right-0 w-80 h-80 bg-purple-500/20 blur-[140px] rounded-full"></div>

  <div class="relative max-w-7xl mx-auto">
    <div class="text-center mb-14">
      <p class="text-indigo-400 uppercase tracking-[4px] text-sm mb-3">My Expertise</p>
      <h2 class="text-3xl md:text-5xl font-bold mb-4">Skills &
        <span class="bg-gradient-to-r from-indigo-400 to-purple-500 text-transparent bg-clip-text">Technologies</span>
        <p class="text-gray-400 max-w-2xl mx-auto text-sm md:text-base leading-relaxed">Technologies and tools I use to build scalable, modern and high performance web applications.</p>
      </h2>
    </div>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {skills.map((category) => (
        <div class="group relative overflow-hidden rounded-3xl border border-white/10 bg-white/5 backdrop-blur-xl p-6 hover:border-indigo-500/40 hover:bg-white/[0.07] transition-all duration-300 hover:-translate-y-1">
          <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition duration-500 bg-gradient-to-br from-indigo-500/10 to-purple-500/10"></div>
          <div class="relative flex items-center gap-4 mb-6">
            <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center shadow-lg shadow-indigo-500/20">
              <ion-icon name={category.icon} style="font-size: 26px; color: white;"></ion-icon>
            </div>
            <div>
              <h3 class="text-xl font-bold text-white">{category.title}</h3>
              <p class="text-gray-400 text-sm">{category.items.length} Technologies</p>
            </div>
          </div>

          <div class="flex flex-wrap gap-3">
            {category.items.map((item) => (
              <div class="flex items-center gap-2 px-4 py-2 rounded-xl bg-[#0f172a]/80 border border-white/10 hover:border-indigo-500/40 hover:bg-indigo-500/10 transition duration-300">
                <img src={item.icon} alt={item.name} class="w-5 h-5 object-contain"/>
                <span class="text-sm text-gray-300">{item.name}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
      <!-- <div class="flex justify-center mt-12">
        <button class="px-6 py-3 rounded-xl  bg-gradient-to-r from-indigo-500 to-purple-600 hover:from-indigo-400 hover:to-purple-500 transition text-white font-medium shadow-lg shadow-indigo-500/20">View All Skills</button>
      </div> -->
  </div>

</section>