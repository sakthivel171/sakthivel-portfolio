---

<section id="contact" class="relative overflow-hidden min-h-screen bg-gradient-to-br from-[#020617] via-[#0f172a] to-[#020617] text-white flex items-center justify-center px-4 py-8 scroll-mt-15">

  <div class="absolute top-0 left-0 w-80 h-80 bg-indigo-500/20 blur-[140px] rounded-full"></div>
  <div class="absolute bottom-0 right-0 w-80 h-80 bg-purple-500/20 blur-[140px] rounded-full"></div>

  <div class="relative w-full max-w-6xl grid lg:grid-cols-2 gap-12 items-center">

    <div>
      <p class="text-indigo-400 uppercase tracking-[4px] text-sm mb-4">Contact Me</p>
      <h1 class="text-4xl md:text-6xl font-bold leading-tight mb-6">
        Let’s Build Something
        <span class="bg-gradient-to-r from-indigo-400 to-purple-500 text-transparent bg-clip-text">
          Great
        </span>
      </h1>

      <p class="text-gray-400 text-base leading-relaxed mb-8 max-w-xl">Have a project in mind? Reach out and let's start a conversation.</p>

      <div class="space-y-5 mb-10">
        <div class="flex items-center gap-4">

            <div class="w-12 h-12 rounded-xl bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center">
                <ion-icon name="mail-outline" style="font-size: 22px; color: #818cf8;"></ion-icon>
            </div>

            <div>
                <p class="text-sm text-gray-500">Email</p>
                <a href="mailto:sakthiveln.tech@gmail.com" class="text-white font-medium">sakthiveln.tech@gmail.com</a>
            </div>
        </div>  

        <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-purple-500/10 border border-purple-500/20 flex items-center justify-center">
                <ion-icon name="call-outline" style="font-size: 22px; color: #c084fc;"></ion-icon>
            </div>

          <div>
            <p class="text-sm text-gray-500">Phone</p>
            <a href="tel:+91 9843217364" class="text-white font-medium">+91 9843217364</a>
          </div>
        </div>

        <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-pink-500/10 border border-pink-500/20 flex items-center justify-center">
                <ion-icon  name="location-outline"style="font-size: 22px; color: #f472b6;"></ion-icon>
            </div>

            <div>
                <p class="text-sm text-gray-500">Location</p>
                <p class="text-white font-medium"> Chennai, Tamil Nadu</p>
            </div>
        </div>
      </div>

      <div class="flex items-center gap-4 mt-6">
  {
    icons.map((item) => (
      <a
        href={item.link}
        target="_blank"
        aria-label={item.name}
        class="w-12 h-12 flex items-center justify-center rounded-xl bg-[#111827] text-indigo-400 hover:bg-indigo-500 hover:text-white transition-all duration-300 hover:scale-110 shadow-lg shadow-indigo-500/20"
      >
        <ion-icon name={item.icon} class="text-2xl"></ion-icon>
      </a>
    ))
  }
</div>
    </div>

    <div class="relative">
      <div class="absolute inset-0 bg-gradient-to-br from-indigo-500/10 to-purple-500/10 blur-3xl"></div>
      <form id="contact-form" class="relative space-y-5 bg-white/[0.04] backdrop-blur-2xl border border-white/10 p-6 md:p-8 rounded-3xl shadow-2xl shadow-indigo-500/10">
        <div class="mb-4">
          <h2 class="text-2xl font-bold mb-2">Send a Message</h2>
          <p class="text-gray-400 text-sm"> Fill out the form below and I'll get back to you soon. </p>
        </div>

        <div>
          <input id="name" type="text" placeholder="Enter Your Name" class="w-full py-3.5 px-5 rounded-xl bg-[#0f172a]/80 border border-white/10 text-white placeholder-gray-500 outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 transition duration-300"/>
          <p id="name-error" class="text-red-400 text-sm  hidden"></p>
        </div>

        <div>
          <input id="email" type="email" placeholder="Enter Your Email" class="w-full py-3.5 px-5 rounded-xl bg-[#0f172a]/80 border border-white/10 text-white placeholder-gray-500 outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 transition duration-300"/>
          <p id="email-error" class="text-red-400 text-sm hidden"></p>
        </div>

        <input id="subject" type="text" placeholder="Subject" class="w-full py-3.5 px-5 rounded-xl bg-[#0f172a]/80 border border-white/10 text-white placeholder-gray-500 outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 transition duration-300"/>

        <div>
          <textarea id="message" rows="5" placeholder="Write Your Message..." class="w-full py-3.5 px-5 rounded-xl bg-[#0f172a]/80 border border-white/10 text-white placeholder-gray-500 outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 transition duration-300 resize-none"></textarea>
         <p id="message-error" class="text-red-400 text-sm hidden"></p>
        </div>
        
        <div>
          <button type="submit" class="w-full py-3.5 rounded-xl bg-gradient-to-r from-indigo-500 to-purple-600 hover:from-indigo-400 hover:to-purple-500 transition duration-300 text-white font-semibold shadow-lg shadow-indigo-500/30 hover:shadow-indigo-500/50 hover:-translate-y-0.5">
            Send Message →
          </button>
        </div>
      </form>
    </div>
  </div>
</section>

<script is:inline>

  const form = document.getElementById("contact-form");
  const btn = form?.querySelector("button[type='submit']");

  const nameInput = document.getElementById("name");
  const emailInput = document.getElementById("email");
  const messageInput = document.getElementById("message");

  const nameError = document.getElementById("name-error");
  const emailError = document.getElementById("email-error");
  const messageError = document.getElementById("message-error");

  function showError(element, message) {
    element.textContent = message;
    element.classList.remove("hidden");
  }

  function hideError(element) {
    element.textContent = "";
    element.classList.add("hidden");
  }

  function validateEmail(email) {
    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
  }

  form?.addEventListener("submit", async (e) => {

    e.preventDefault();

    let valid = true;

    const name = nameInput.value.trim();
    const email = emailInput.value.trim();
    const message = messageInput.value.trim();
    const subject = document.getElementById("subject").value.trim();

    hideError(nameError);
    hideError(emailError);
    hideError(messageError);

    // NAME
    if (!name) {
      showError(nameError, "Name field is required");
      valid = false;
    }

    // EMAIL
    if (!email) {
      showError(emailError, "Email is required");
      valid = false;
    } else if (!validateEmail(email)) {
      showError(emailError, "Enter valid email address");
      valid = false;
    }

    // MESSAGE
    if (!message) {
      showError(messageError, "Message field is required");
      valid = false;
    }

    if (!valid) return;

    if (btn) {
      btn.disabled = true;
      btn.textContent = "Sending...";
    }

    try {

      const res = await fetch("/api/contact", {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          name, email, subject, message
        })
      });

      const data = await res.json();

      if (data.success) {
        alert("Message sent successfully!");
        form.reset();

        if (btn) {
          btn.textContent = "✅ Sent!";
        }

        setTimeout(() => {
          if (btn) {
            btn.textContent = "Send Message →";
          }
        }, 3000);

      } else {
        alert("Failed to send message.");
      }

    } catch (error) {

      alert("Something went wrong.");

    } finally {

      if (btn) {
        btn.disabled = false;
      }
    }
  });
</script>