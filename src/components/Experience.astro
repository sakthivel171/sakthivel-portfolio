---
const experience = [
  {
    role: "Junior Full Stack Developer",
    company: "Uzhavarbumi Agro Products Pvt Ltd",
    period: "sep 2025 - Present",
    icon: "briefcase-outline",
    current: true,
    points: [
     "Developed Customer, Dealer and Delivery Apps for business operations.",
      "Built responsive dashboards using Vue.js and Tailwind CSS.",
      "Integrated REST APIs via Axios for frontend-backend communication.",
      "Created reusable components and optimized app performance.",
    ],
    tech:["Vue.js","Tailwind CSS","Bootstrap","Laravel","MYSQL","Livewire", "Gitea"],
  },
  {
    role: "Web Development Intern",
    company: "Vdart Pvt Ltd",
    period: "Jun 2025 - Aug 2025",
    icon: "rocket-outline",
    current: false,
    points: [
      "Worked on frontend development and responsive UI design.",
      "Learned REST API integration and backend communication.",
      "Collaborated with developers to build web applications.",
    ],
    tech: ["HTML","CSS","Tailwind CSS","AWS"],
  }
];

---

<section class="relative overflow-hidden bg-[#050816] text-white py-20 px-4 sm:px-6 lg:px-8">
  <div class="absolute top-0 left-0 w-80 h-80 bg-indigo-500/10 blur-[120px] rounded-full"></div>
  <div class="absolute bottom-0 right-0 w-80 h-80 bg-purple-500/10 blur-[120px] rounded-full"></div>

  <div class="relative max-w-4xl mx-auto">
    <div class="text-center mb-4">

      <div class="text-center mb-14">
        <p class="text-indigo-400 uppercase tracking-[4px] text-xs mb-3">Career Journey</p>
        <h2 class="text-3xl md:text-4xl mx-auto text-sm leading-relaxed">
          Building sclable Applications,responsive interfaces and optimized backend systems.
        </h2>
      </div>

      <div class="relative">
         <div class="absolute left-6 top-0 bottom-0 w-px bg-gradient-to-b from-indigo-500 via-purple-500 to-transparent"></div>
          <div class="space-y-8">
            {experience.map((exp) => (
              <div class="relative pl-16 group">

                <div class="absolute left-0 top-6 flex items-center justify-center w-12 h-12 rounded-2xl bg-gradient-to-br from-indigo-500 to-purple-600 shadow-lg shadow-indigo-500 border-2 border-[#050816] z-10">
                  <ion-icon name={exp.icon} style="font-size: 20px;color: white;;"></ion-icon>
                </div>
                <div class="relative bg-white/5 border border-white/10 rounded-2xl p-6 hover:border-indigo-500/40 hover:bg-white/[0.07] transition duration-300">
                  <div class="flex flex-wrap items-start justify-between gap-3 mb-4">
                    <div>
                      <div class="flex items-center gap-2 mb-1">
                        <h3 class="text-lg font-bold">{exp.role}</h3>
                          {exp.current && (
                            <span class="flex items-center gap-1.5 px-2.5 py-0.5 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-[11px] font-medium">current</span>
                          )}
                      </div>
                      <div class="flex items-center gap-1.5 text-indigo-400 text-sm">
                        <ion-icon name="business-outline" style="font-size: 14px;"></ion-icon>
                        {exp.company}
                      </div>
                    </div>

                    <div class="flex items-center gap-1.5 px-3 py-1.5 rounded-xl bg-white/5 border border-white/10 text-gray-400 text-xs">
                      <ion-icon name="calendar-outline" style="font-size: 13px;"></ion-icon>
                      {exp.period}
                    </div>
                  </div>

                  <div class="space-y-2 mb-5">
                    {exp.points.map((point) => (
                      <div class="flex items-start gap-2.5">
                        <ion-icon name="chevron-forward-outline" style="font-size: 14px; color: #818cf8; margin-top: 3px; flex-shrink: 0;"></ion-icon>
                        <p class="text-gray-400 text-sm leading-relaxed">{point}</p>
                      </div>
                    ))}
                  </div>

                  <div class="flex flex-wrap gap-2">
                    {exp.tech.map((tech) => (
                      <span class="px-3 py-1 rounded-lg bg-indigo-500/20 border border-indigo-500/20 text-indigo-300 text-xs font-medium">{tech}</span>
                    ))}
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>